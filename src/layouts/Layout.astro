---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Hi! I'm Liam Piesley, a software engineer in London."
    />
    <meta property="og:image:url" content="https://liamp.uk/res/banner.jpg" />
    <title>Liam Piesley.</title>
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="favicon.svg"
    />
    <link
      rel="icon"
      type="image/svg"
      sizes="32x32"
      href="favicon.svg"
    />
    <link
      rel="preload"
      href="/PPEditorialOld-Regular-Subset.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <!-- Prioritise Window 3D asset so it loads before Feed media -->
    <link rel="preload" href="/tree_small-opt.glb" as="fetch" crossorigin />
  </head>
  <body>
    <!-- Lock initial viewport height before any content so layout doesn’t shift when browser chrome hides -->
    <script is:inline>
      (function () {
        var h = typeof window !== 'undefined' && (window.visualViewport ? window.visualViewport.height : window.innerHeight);
        if (h > 0) document.documentElement.style.setProperty('--initial-viewport-height', h + 'px');
      })();
    </script>
    <slot />
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    height: auto;
    box-sizing: border-box;
    background-color: #eeedec;
    overscroll-behavior: auto;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;

    background-color: #eeedec;
    z-index: -1;
  }

  @font-face {
    font-family: 'Editorial Old';
    src: url('/PPEditorialOld-Regular-Subset.woff2') format('woff2');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }
</style>
