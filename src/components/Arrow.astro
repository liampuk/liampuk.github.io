---
/** Inline arrow SVG matching Mac/system font style: small, rounded strokes */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---
<svg
  class:list={[className]}
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 6 6"
  width="1.5em"
  height="1em"
  fill="none"
  stroke="currentColor"
  stroke-width="0.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <path d="M 1 3 H 4 L 6 3 L 4 1 M 6 3 L 4 5" />
</svg>

<style>
  svg {
    display: inline-block;
    margin-right: 0.2em;
    margin-left: -0.1em;
    font-size: 12px;
  }
</style>
